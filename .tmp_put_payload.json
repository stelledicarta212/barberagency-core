                                         "jsCode":  "const body = $json.body || {};\nconst msg0 = (body.conversation \u0026\u0026 Array.isArray(body.conversation.messages) \u0026\u0026 body.conversation.messages.length)\n  ? body.conversation.messages[0]\n  : {};\n\nconst attachments = body.attachments || msg0.attachments || [];\nconst first = attachments[0] || {};\n\nconst mime = (first.file_type || first.content_type || \u0027\u0027).toLowerCase();\nconst contentType = (body.content_type || \u0027\u0027).toLowerCase();\n\nlet modality = \u0027text\u0027;\nif (attachments.length \u003e 0) {\n  if (mime.startsWith(\u0027image/\u0027)) modality = \u0027image\u0027;\n  else if (mime.startsWith(\u0027audio/\u0027)) modality = \u0027audio\u0027;\n  else if (mime.startsWith(\u0027video/\u0027)) modality = \u0027video\u0027;\n  else modality = \u0027file\u0027;\n} else if (contentType \u0026\u0026 contentType !== \u0027text\u0027) {\n  modality = contentType;\n}\n\nconst mediaUrl = first.data_url || first.thumb_url || first.url || null;\n\nreturn [{\n  json: {\n    event: body.event || null,\n    message_type: body.message_type || null,\n    content_type: body.content_type || null,\n    content: body.content || \u0027\u0027,\n    conversation_id: msg0.conversation_id || (body.conversation \u0026\u0026 body.conversation.id) || null,\n    phone_number: (msg0.sender \u0026\u0026 msg0.sender.phone_number) || (body.sender \u0026\u0026 body.sender.phone_number) || null,\n    modality,\n    media_url: mediaUrl,\n    media_mime: mime,\n    attachments_count: attachments.length,\n    attachments,\n  }\n}];"
