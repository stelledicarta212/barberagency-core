          "host": ["{{POSTGREST_BASE}}"],
          "path": ["barberos"],
          "query": [
            { "key": "barberia_id", "value": "eq.{{BARBERIA_ID}}" },
            { "key": "activo", "value": "eq.true" },
            { "key": "select", "value": "id,barberia_id,nombre,activo" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
              "const rows = pm.response.json();",
              "pm.test('Barberos > 0', function () { pm.expect(Array.isArray(rows) ? rows.length : 0).to.be.above(0); });"
            ]
          }
        }
      ]
    },
