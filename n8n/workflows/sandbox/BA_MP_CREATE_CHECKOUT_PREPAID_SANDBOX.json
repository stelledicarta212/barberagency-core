    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE public.billing_checkouts \nSET provider_checkout_id = '{{ $json.id }}', \n    init_point = '{{ $json.init_point }}',\n    updated_at = now() \nWHERE id = '{{ $node[\"PG - Create Checkout\"].json.checkout_id }}'\nRETURNING id, external_reference, init_point;"
      },
