    {
      "parameters": {
        "jsCode": "const i = $input.first().json || {};\nconst h = i.headers || {};\nlet cookieToken = '';\nlet bearerToken = '';\n\nconst cookieHeader = (h.cookie ?? h.Cookie ?? '').toString();\nconst cookieMatch = cookieHeader.match(/(?:^|;\\s*)ba_session=([^;]+)/);\nif (cookieMatch) {\n  cookieToken = cookieMatch[1].trim();\n}\n\nconst authHeader = (h.authorization ?? h.Authorization ?? '').toString().trim();\nif (authHeader.startsWith('Bearer ')) {\n  bearerToken = authHeader.substring(7).trim();\n}\n\nlet session_token = '';\nlet conflict = false;\n\nif (cookieToken && bearerToken) {\n  if (cookieToken !== bearerToken) {\n    conflict = true;\n  } else {\n    session_token = cookieToken;\n  }\n} else if (cookieToken) {\n  session_token = cookieToken;\n} else if (bearerToken) {\n  session_token = bearerToken;\n}\n\nreturn [{ json: { session_token, conflict } }];"
      },
      "id": "code-parse-cookie",
      "name": "Code - parse cookie",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        280,
        200
      ]
