    {
      "parameters": {
        "jsCode": "const i = $input.first().json || {};\nconst inputData = $node[\"Code - parse cookie\"].json || {};\n\nlet auth_ok = false;\nlet user_id = 0;\nlet error_message = \"\";\n\nif (inputData.conflict) {\n  error_message = \"Conflicto de sesión: Múltiples tokens contradictorios.\";\n} else if (i.error) {\n  error_message = \"Firma o formato del token inválido: \" + String(i.error);\n} else if (!i.payload) {\n  error_message = \"Payload ausente.\";\n} else {\n  const payload = i.payload;\n  \n  if (payload.exp === undefined || payload.exp === null) {\n    error_message = \"Token no contiene claim exp.\";\n  } else if (payload.user_id === undefined || payload.user_id === null) {\n    error_message = \"Token no contiene claim user_id.\";\n  } else {\n    const rawUserId = Number(payload.user_id);\n    if (!Number.isInteger(rawUserId) || rawUserId <= 0) {\n      error_message = \"User ID debe ser un entero positivo.\";\n    } else if (payload.iss !== 'barberagency_auth') {\n      error_message = \"Issuer no coincide.\";\n    } else if (payload.aud !== 'barberagency_app') {\n      error_message = \"Audience no coincide.\";\n    } else {\n      auth_ok = true;\n      user_id = rawUserId;\n    }\n  }\n}\n\nreturn [{ json: { auth_ok, user_id, error_message } }];"
      },
