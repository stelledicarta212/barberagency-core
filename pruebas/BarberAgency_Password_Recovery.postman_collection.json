{
	"info": {
		"_postman_id": "8c3b4c9a-b4d2-43f1-b956-62164cfa228f",
		"name": "BarberAgency - Password Recovery Flow",
		"description": "Colección de Postman para probar el sistema auto-servicio de recuperación de contraseña de BarberAgency, implementado con n8n y Gmail OAuth2.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Solicitar Recuperación (Request Recovery)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"La respuesta es exitosa\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.ok).to.eql(true);",
							"});"
						],
						"type": "javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"jean@gmail.com\"\n}"
				},
				"url": {
					"raw": "https://barberagency-n8n.gymh5g.easypanel.host/webhook/barberagency/dashboard/recover/request",
					"protocol": "https",
					"host": [
						"barberagency-n8n",
						"gymh5g",
						"easypanel",
						"host"
					],
					"path": [
						"webhook",
						"barberagency",
						"dashboard",
						"recover",
						"request"
					]
				},
				"description": "Inicia el proceso de recuperación. \nEnvia un correo electrónico con el enlace único. Puedes cambiar el email al tuyo (por ejemplo: clopez@gmail.com) para ver el correo real enviado directamente desde tu Gmail."
			},
			"response": []
		},
		{
			"name": "2. Restablecer Contraseña (Reset Password)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"La contraseña se restableció con éxito\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.ok).to.eql(true);",
							"    pm.expect(jsonData.message).to.include(\"restablecida correctamente\");",
							"});"
						],
						"type": "javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"token\": \"AQUÍ_VA_EL_TOKEN_UUID_RECIBIDO_EN_TU_EMAIL_O_DE_LA_BD\",\n  \"new_password\": \"NuevaClave123!\"\n}"
				},
				"url": {
					"raw": "https://barberagency-n8n.gymh5g.easypanel.host/webhook/barberagency/dashboard/recover/reset",
					"protocol": "https",
					"host": [
						"barberagency-n8n",
						"gymh5g",
						"easypanel",
						"host"
					],
					"path": [
						"webhook",
						"barberagency",
						"dashboard",
						"recover",
						"reset"
					]
				},
				"description": "Restablece la contraseña del usuario. \nReemplaza el token por el que te llegó a tu cuenta de Gmail (o el token UUID generado en la tabla public.password_resets)."
			},
			"response": []
		},
		{
			"name": "3. Probar Reuso / Seguridad (Replay Attack)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 400 Bad Request\", function () {",
							"    pm.response.to.have.status(400);",
							"});",
							"",
							"pm.test(\"El token gastado es rechazado correctamente\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.ok).to.eql(false);",
							"    pm.expect(jsonData.message).to.include(\"inválido, ya fue utilizado o ha expirado\");",
							"});"
						],
						"type": "javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"token\": \"AQUÍ_VA_EL_MISMO_TOKEN_UUID_USADO_EN_EL_PASO_2\",\n  \"new_password\": \"NuevaClave123!\"\n}"
				},
				"url": {
					"raw": "https://barberagency-n8n.gymh5g.easypanel.host/webhook/barberagency/dashboard/recover/reset",
					"protocol": "https",
					"host": [
						"barberagency-n8n",
						"gymh5g",
						"easypanel",
						"host"
					],
					"path": [
						"webhook",
						"barberagency",
						"dashboard",
						"recover",
						"reset"
					]
				},
				"description": "Valida que un token ya utilizado no pueda volver a usarse (Política de seguridad de Un solo Uso). \nDebería devolver obligatoriamente un código HTTP 400 Bad Request con un mensaje de error claro."
			},
			"response": []
		}
	]
}
