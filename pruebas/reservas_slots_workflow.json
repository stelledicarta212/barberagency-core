    {
      "parameters": {
        "resource": "database",
        "operation": "executeQuery",
        "query": "SELECT public.ba_reservas_public_slots(\n  $1::int,\n  $2::text,\n  $3::int,\n  $4::int,\n  $5::date\n) AS result;",
        "options": {
          "queryReplacement": "={{ [$json.barberia_id, $json.slug, $json.servicio_id, $json.barbero_id, $json.fecha] }}"
        }
