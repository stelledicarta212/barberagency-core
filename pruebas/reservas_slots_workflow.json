      {
        "parameters": {
          "resource": "database",
          "operation": "executeQuery",
          "query": "\n            SELECT\n              barberia_id,\n              barbero_id,\n              fecha,\n              hora_inicio,\n              hora_fin\n            FROM public.v_slots_disponibles\n            WHERE barberia_id = $1\n              AND fecha = $2::date\n              AND ($3::int IS NULL OR barbero_id = $3::int)\n              AND (\n                fecha > (now() AT TIME ZONE 'America/Bogota')::date\n                OR hora_inicio > (now() AT TIME ZONE 'America/Bogota')::time\n              )\n            ORDER BY barbero_id ASC, hora_inicio ASC;\n          ",
          "options": {
            "queryReplacement": "={{ [$json.barberia_id, $json.fecha, $json.barbero_id] }}"
          }
        },
