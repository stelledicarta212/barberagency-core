      {
        "parameters": {
          "mode": "runOnceForAllItems",
          "language": "javaScript",
          "jsCode": "\n    const validRows = $input.all()\n      .map((item) => item.json || {})\n      .filter((row) =>\n        Number(row.barberia_id) > 0 &&\n        Number(row.barbero_id) > 0 &&\n        String(row.fecha || '').trim() &&\n        String(row.hora_inicio || '').trim()\n      );\n\n    const first = validRows[0] || {};\n    const slots = validRows.map((row) => ({\n      barberia_id: Number(row.barberia_id),\n      barbero_id: Number(row.barbero_id),\n      fecha: String(row.fecha || '').slice(0, 10),\n      hora_inicio: String(row.hora_inicio || '').slice(0, 5),\n      hora_fin: String(row.hora_fin || '').slice(0, 5)\n    }));\n\n    return [{\n      json: {\n        ok: true,\n        barberia_id: Number(first.barberia_id || 0) || null,\n        fecha: String(first.fecha || '').slice(0, 10) || null,\n        count: slots.length,\n        slots\n      }\n    }];\n  "
        },
